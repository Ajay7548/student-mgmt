# ---------------------------------------------------------------------------
# Backend environment variables (EXAMPLE)
# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values:
#     cp .env.example .env
# The ".env" file is git-ignored so your secrets never get committed.
# ---------------------------------------------------------------------------

# The TCP port the Express server listens on.
PORT=5000

# MongoDB connection string.
#  - Local MongoDB:  mongodb://127.0.0.1:27017/student-mgmt
#  - MongoDB Atlas:  mongodb+srv://<user>:<password>@<cluster>/student-mgmt
MONGODB_URI=mongodb://127.0.0.1:27017/student-mgmt

# Secret key used for the SERVER-SIDE (level-2) AES encryption layer.
# This must be a long, random string and must be kept private.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_ENCRYPTION_KEY=replace-with-a-long-random-server-side-secret

# Origin allowed to call this API (your frontend dev server URL).
# Used by CORS to block requests from unknown websites.
CLIENT_ORIGIN=http://localhost:5173
