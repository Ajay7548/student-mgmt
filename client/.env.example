# ---------------------------------------------------------------------------
# Frontend environment variables (EXAMPLE)
# ---------------------------------------------------------------------------
# Copy this file to ".env" and adjust if needed:
#     cp .env.example .env
#
# NOTE: Vite only exposes variables that begin with the "VITE_" prefix to the
# browser. Anything else stays hidden from client-side code.
# ---------------------------------------------------------------------------

# Base URL of the backend API the frontend talks to.
VITE_API_BASE_URL=http://localhost:5000/api

# Secret key for the CLIENT-SIDE (level-1) AES encryption layer.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# SECURITY NOTE: any value shipped to the browser is, by definition, visible to a
# determined user. This key protects data IN TRANSIT and adds the outer wrapper of
# the two-layer scheme; it is not a substitute for server-side secrets. See the
# "How encryption is implemented" section of the README for the full explanation.
VITE_CLIENT_ENCRYPTION_KEY=replace-with-a-long-random-client-side-secret

# Demo login credentials for the gate on the Login page (see README → Authentication).
VITE_DEMO_EMAIL=admin@example.com
VITE_DEMO_PASSWORD=Admin@1234
